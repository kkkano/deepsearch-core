# ============================================================
# deepsearch-core 配置模板
# 复制为 .env 后填入真实值
# ============================================================

# ---------- LLM 配置（必填）----------
# 任何 OpenAI 兼容 endpoint：Anthropic、OpenAI、DeepSeek、Qwen、x666.me、本地 vLLM 等
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-xxx

# 节点级模型配置（按需调整，省钱关键）
SUPERVISOR_MODEL=claude-sonnet-4-6
PLANNER_MODEL=claude-haiku-4-5
RESEARCHER_MODEL=claude-haiku-4-5
CRITIC_MODEL=claude-sonnet-4-6
REPORTER_MODEL=claude-opus-4-7

# 各节点 temperature
SUPERVISOR_TEMPERATURE=0
PLANNER_TEMPERATURE=0
RESEARCHER_TEMPERATURE=0
CRITIC_TEMPERATURE=0.2
REPORTER_TEMPERATURE=0.3

# ---------- 搜索引擎（至少配置一个）----------
TAVILY_API_KEY=tvly-xxx
SERPER_API_KEY=
FIRECRAWL_API_KEY=
JINA_READER_API_KEY=

# 学术源
CROSSREF_BASE_URL=https://api.crossref.org
CROSSREF_MAILTO=657394554@qq.com  # 礼貌池，提速

# ---------- Reranker（强烈推荐）----------
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# ---------- 引擎参数 ----------
MAX_AGENTS_FAN_OUT=4              # 并行 agent 数
MAX_STEPS_PER_RESEARCH=8          # 每个 researcher 最多迭代次数
SEARCH_MAX_RESULTS_PER_QUERY=10
MAX_SOURCES_PER_STEP=5
MAX_READ_SOURCES_PER_STEP=3
TASK_TIMEOUT_SECONDS=300

# ---------- Source Policy ----------
DEFAULT_POLICY=general            # general / finance / tech / academic
POLICY_DIR=./deepsearch_core/policy/policies

# ---------- 存储 ----------
EVENT_STORE_DSN=sqlite:///./runs.db
ENABLE_EVENT_SOURCING=true

# ---------- HTTP / MCP Server ----------
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
MCP_TRANSPORT=stdio              # stdio / http / sse
MCP_PORT=8765

# ---------- 可观测性 ----------
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING / ERROR
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
